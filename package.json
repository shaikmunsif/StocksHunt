{
  "name": "stocks-pulse",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node set-env.js",
    "start": "ng serve",
    "prebuild:prod": "node set-env.js --prod",
    "build": "npm run prebuild:prod && ng build --configuration production",
    "build:dev": "node set-env.js && ng build --configuration development",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.16",
    "@angular/cdk": "^21.2.14",
    "@angular/common": "^21.2.16",
    "@angular/compiler": "^21.2.16",
    "@angular/core": "^21.2.16",
    "@angular/forms": "^21.2.16",
    "@angular/material": "^21.2.14",
    "@angular/platform-browser": "^21.2.16",
    "@angular/router": "^21.2.16",
    "@ngrx/signals": "^21.1.0",
    "@supabase/supabase-js": "^2.81.1",
    "@tailwindcss/line-clamp": "^0.4.4",
    "autoprefixer": "^10.5.0",
    "chart.js": "^4.5.1",
    "rxjs": "~7.8.0",
    "tailwindcss": "^3.4.19",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.14",
    "@angular/cli": "^21.2.14",
    "@angular/compiler-cli": "^21.2.16",
    "@types/jasmine": "~5.1.0",
    "dotenv": "^17.2.3",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.6",
    "typescript": "~5.9.2"
  }
}
